# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_for_uat
POSTGRES_DB=devop_uat

# Backend runtime
SESSION_SECRET=replace_with_long_random_secret
SESSION_COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# OAuth (set real values for UAT)
GOOGLE_CLIENT_ID=your_uat_google_client_id
GOOGLE_CLIENT_SECRET=your_uat_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# UAT host port (optional override)
UAT_PORT=8080
